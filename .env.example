PORT=3011
OLLAMA_URL=http://127.0.0.1:11434
DEFAULT_MODEL=llama3:latest
UPSTREAM_TIMEOUT_MS=15000
OLLAMA_STREAM_TIMEOUT_MS=120000
OLLAMA_FIRST_CHUNK_TIMEOUT_MS=60000
VISION_CHAT_MODEL=qwen2.5vl:7b
# Comma-separated API keys for gateway auth (see index.js)
API_KEYS=

# Студия: сборка превью — auto (Docker если доступен) | docker | host
# STUDIO_BUILD_EXECUTOR=auto
# STUDIO_DOCKER_IMAGE=ollama-studio-runner:local
# STUDIO_BUILD_TIMEOUT_MS=600000
# После ошибки npm/vite: число раундов «LLM-патч → снова сборка» (0 — только одна сборка, как раньше)
# STUDIO_BUILD_RECOVERY_MAX_ROUNDS=3
# Макс. операций в одном патче починки
# STUDIO_BUILD_RECOVERY_MAX_OPS=25
# STUDIO_DOCKER_MEMORY=2g
# STUDIO_DOCKER_CPUS=2
# Изолированная сеть Docker для npm ci (создать: docker network create studio_isolated)
# STUDIO_DOCKER_NETWORK=studio_isolated
# Явный uid:gid для npm в контейнере (если не задано — берётся из процесса API, чтобы писать в примонтированный workspace):
# STUDIO_DOCKER_USER=33:33

# Публичные ссылки /preview/ (HMAC; на проде задать длинный секрет)
# STUDIO_PREVIEW_SECRET=
# STUDIO_PREVIEW_TTL_MS=2700000
# STUDIO_MAX_BUILDS_GLOBAL=20
# STUDIO_MAX_BUILDS_PER_USER=2
# Если агент записал несуществующий диапазон lucide-react (^0.5.0), перед npm подставляется:
# STUDIO_NPM_LUCIDE_REACT=^1.0.0

# Студия /agent/run: если Ollama offline — облако (ключи только в env на сервере, не коммитить)
# STUDIO_LLM_FALLBACK_ORDER=anthropic,openai,gemini
# Порядок по типу задачи (перекрывает STUDIO_LLM_FALLBACK_ORDER для stream):
# STUDIO_LLM_ORDER_STREAM=anthropic,openai,gemini
# Диалог студии (agent/chat) — те же stream-модели; если не задано, как STREAM:
# STUDIO_LLM_ORDER_CHAT=anthropic,openai,gemini
# STUDIO_LLM_ORDER_JSON=openai,anthropic,gemini
# STUDIO_CLOUD_MAX_TOKENS=8192
# Лимит вывода для «лёгких» облачных запросов (приветствия, короткий Q&A):
# STUDIO_CLOUD_MAX_TOKENS_LITE=4096
# Порядок провайдеров для lite (по умолчанию в коде: gemini,openai,anthropic):
# STUDIO_LLM_ORDER_STREAM_LITE=gemini,openai,anthropic
# Дешёвые модели для stream/chat (json/PATCH всегда использует «тяжёлые»):
# ANTHROPIC_MODEL_STREAM_LITE=claude-3-5-haiku-20241022
# OPENAI_STUDIO_MODEL_STREAM_LITE=gpt-4o-mini
# GEMINI_STUDIO_MODEL_STREAM_LITE=gemini-2.0-flash
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL_STREAM=claude-sonnet-4-20250514
# ANTHROPIC_MODEL_JSON=claude-sonnet-4-20250514
# OPENAI_API_KEY=
# OPENAI_STUDIO_MODEL_STREAM=gpt-4o
# OPENAI_STUDIO_MODEL_JSON=gpt-4o
# OPENAI_STUDIO_MODEL=gpt-4o
# GOOGLE_AI_API_KEY=
# GEMINI_API_KEY=
# GEMINI_STUDIO_MODEL_STREAM=gemini-2.0-flash
# GEMINI_STUDIO_MODEL_JSON=gemini-2.0-flash
# GEMINI_STUDIO_MODEL=gemini-2.0-flash
#
# Локальный тест API с отдельным файлом секретов (ollama-api/.env.test — в .gitignore):
#   cd ollama-api && npm run start:test-keys
# Или один файл по умолчанию .env и явный путь:
#   DOTENV_CONFIG_PATH=/absolute/path/.env.custom  node ollama-api/index.js
# (относительный DOTENV_CONFIG_PATH резолвится от каталога index.js.)
