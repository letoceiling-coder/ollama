PORT=3011
OLLAMA_URL=http://127.0.0.1:11434
DEFAULT_MODEL=llama3:latest
UPSTREAM_TIMEOUT_MS=15000
OLLAMA_STREAM_TIMEOUT_MS=120000
OLLAMA_FIRST_CHUNK_TIMEOUT_MS=60000
VISION_CHAT_MODEL=qwen2.5vl:7b
# Comma-separated API keys for gateway auth (see index.js)
API_KEYS=

# Студия: сборка превью — auto (Docker если доступен) | docker | host
# STUDIO_BUILD_EXECUTOR=auto
# STUDIO_DOCKER_IMAGE=ollama-studio-runner:local
# STUDIO_BUILD_TIMEOUT_MS=600000
# STUDIO_DOCKER_MEMORY=2g
# STUDIO_DOCKER_CPUS=2
# Изолированная сеть Docker для npm ci (создать: docker network create studio_isolated)
# STUDIO_DOCKER_NETWORK=studio_isolated
#
# Публичные ссылки /preview/ (HMAC; на проде задать длинный секрет)
# STUDIO_PREVIEW_SECRET=
# STUDIO_PREVIEW_TTL_MS=2700000
